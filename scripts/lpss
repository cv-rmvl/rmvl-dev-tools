#!/bin/bash

set -eu

function usage() {
  echo -e "\033[1m用法:\033[0m \033[36m$(basename "$0")\033[0m <command> [args...]"
  echo ""
  echo -e "\033[1m命令:\033[0m"
  echo -e "  \033[36mhelp\033[0m      显示详细帮助信息"
  echo -e "  \033[36mcreate\033[0m    创建一个依赖 lpss 的新项目"
  echo -e "  \033[36mnode\033[0m      lpss 节点工具"
  echo -e "  \033[36mtopic\033[0m     lpss 话题工具"
  echo -e "  \033[36minterface\033[0m 内置消息接口查看工具"
  echo -e "  \033[36mgraph\033[0m     前后端分离的 lpss 节点图工具"
  echo -e "  \033[36mviz\033[0m       前后端分离的 lpss 3D 可视化工具"
}

function print_help_banner() {
  local sps="      "
  local c="\033[33;1m" # 黄色加粗
  local r="\033[0m"    # 重置颜色
  
  printf "${sps}${c}╭──────────────────────────────────────────────────────────────────────────╮${r}\n"
  printf "${sps}${c}│${r} LPSS 是一个轻量级的发布订阅通信框架，采用去中心化设计，提供 NDP、EDP 两  ${c}│${r}\n"
  printf "${sps}${c}│${r} 层服务发现机制，以及 MTP 话题消息传输协议，提供类似 ROS2 的 *.msg 消息接 ${c}│${r}\n"
  printf "${sps}${c}│${r} 口，由 RMVL 提供支持。本工具提供了 LPSS 相关的命令行工具，使用方法如下。 ${c}│${r}\n"
  printf "${sps}${c}╰──────────────────────────────────────────────────────────────────────────╯${r}\n"
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

command=$1
shift

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.lpss"

case "$command" in
  help)
    print_help_banner
    usage
    printf '\n更多信息请参考官方手册:\n'
    printf '  使用教程: \033[32m%s\033[0m\n' "https://cv-rmvl.github.io/docs/2.x/d3/d8e/tutorial_modules_lpss.html"
    printf '  API 文档: \033[32m%s\033[0m\n' "https://cv-rmvl.github.io/docs/2.x/d7/de3/group__lpss.html"
    ;;
  create)
    "$script_dir/create.bash" "$@"
    ;;
  node)
    "$script_dir/node.bash" "$@"
    ;;
  topic)
    "$script_dir/topic.bash" "$@"
    ;;
  interface)
    "$script_dir/interface.bash" "$@"
    ;;
  graph)
    if [ -f "$script_dir/_autogen_lpss_graph" ]; then
      "$script_dir/_autogen_lpss_graph" "$@"
    else
      echo "lpss graph 工具尚未实现。敬请期待！"
    fi
    ;;
  viz)
    if [ -f "$script_dir/_autogen_lpss_viz" ]; then
      "$script_dir/_autogen_lpss_viz" "$(uuidgen | cut -c 1-5)"
    else
      echo "lpss viz 工具尚未实现。敬请期待！"
    fi
    ;;
  *)
    echo "未知命令: $command"
    usage
    exit 1
    ;;
esac

