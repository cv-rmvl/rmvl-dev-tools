#!/bin/bash

set -eu

TOOLS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../.." && pwd)"
source "$TOOLS_ROOT/setup/bash/rdtcolor.bash"
rdtcolor_init

function usage() {
  echo -e "${C_BOLD}用法:${C_RESET} ${C_CYAN}$(basename "$0")${C_RESET} <command> ${C_DIM}[args...]${C_RESET}"
  echo ""
  echo -e "${C_BOLD}命令:${C_RESET}"
  echo -e "  ${C_CYAN}help        ${C_DIM}显示详细帮助信息${C_RESET}"
  echo -e "  ${C_CYAN}create      ${C_DIM}创建一个依赖 lpss 的新项目${C_RESET}"
  echo -e "  ${C_CYAN}node        ${C_DIM}节点 CLI 工具${C_RESET}"
  echo -e "  ${C_CYAN}topic       ${C_DIM}话题 CLI 工具${C_RESET}"
  echo -e "  ${C_CYAN}service     ${C_DIM}服务 CLI 工具${C_RESET}"
  echo -e "  ${C_CYAN}interface   ${C_DIM}内置消息接口查看工具${C_RESET}"
  echo -e "  ${C_CYAN}graph       ${C_DIM}节点图工具${C_RESET}"
  echo -e "  ${C_CYAN}viz         ${C_DIM}3D 可视化工具 LViz${C_RESET}"
}

function print_help_banner() {
  local sps="      "
  local c="${C_YELLOW}${C_BOLD}"
  local r="${C_RESET}"
  
  printf "${sps}${c}╭──────────────────────────────────────────────────────────────────────────╮${r}\n"
  printf "${sps}${c}│${r} LPSS 是一个轻量级的发布订阅通信框架，采用去中心化设计，提供 NDP、EDP 两  ${c}│${r}\n"
  printf "${sps}${c}│${r} 层服务发现机制，以及 MTP 话题消息传输协议，提供类似 ROS2 的 *.msg 消息接 ${c}│${r}\n"
  printf "${sps}${c}│${r} 口，由 RMVL 提供支持。本工具提供了 LPSS 相关的命令行工具，使用方法如下。 ${c}│${r}\n"
  printf "${sps}${c}╰──────────────────────────────────────────────────────────────────────────╯${r}\n"
}

if [ $# -lt 1 ]; then
  usage
  exit 1
fi

command=$1
shift

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/.lpss"

case "$command" in
  help)
    print_help_banner
    usage
    echo -e "\n更多信息请参考官方手册:"
    echo -e "  使用教程: ${C_GREEN}https://cv-rmvl.github.io/docs/2.x/d3/d8e/tutorial_modules_lpss.html${C_RESET}"
    echo -e "  API 文档: ${C_GREEN}https://cv-rmvl.github.io/docs/2.x/d7/de3/group__lpss.html${C_RESET}"
    ;;
  create)
    "$script_dir/create.bash" "$@"
    ;;
  node)
    "$script_dir/node.bash" "$@"
    ;;
  topic)
    "$script_dir/topic.bash" "$@"
    ;;
  service)
    "$script_dir/service.bash" "$@"
    ;;
  interface)
    "$script_dir/interface.bash" "$@"
    ;;
  graph)
    if [ -f "$script_dir/_autogen_lpss_graph" ]; then
      "$script_dir/_autogen_lpss_graph" "$@"
    else
      echo "lpss graph 工具尚未实现。敬请期待！"
    fi
    ;;
  viz)
    bash "$script_dir/viz.bash" "$@"
    ;;
  *)
    echo "未知命令: $command"
    usage
    exit 1
    ;;
esac
